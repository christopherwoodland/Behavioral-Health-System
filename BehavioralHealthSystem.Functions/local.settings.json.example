{
  "IsEncrypted": false,
  "ConnectionStrings": {},
  "Host": {
    "LocalHttpPort": 7071,
    "CORS": "http://localhost:5173,http://localhost:5174,https://localhost:5173,https://localhost:5174",
    "CORSCredentials": false
  },
  "Values": {
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",
    "AzureWebJobsStorage__accountName": "<storage-account-name>",
    "DSM5_STORAGE_ACCOUNT_NAME": "<storage-account-name>",
    "APPLICATIONINSIGHTS_CONNECTION_STRING": "@Microsoft.KeyVault(SecretUri=<keyvault-uri>/secrets/AppInsightsConnectionString/)",

    "AZURE_OPENAI_ENABLED": "true",
    "AZURE_OPENAI_ENDPOINT": "https://<your-openai>.openai.azure.com/",
    "AZURE_OPENAI_DEPLOYMENT": "gpt-4.1",
    "AZURE_OPENAI_API_VERSION": "2024-12-01-preview",

    "EXTENDED_ASSESSMENT_OPENAI_ENABLED": "true",
    "EXTENDED_ASSESSMENT_OPENAI_ENDPOINT": "https://<your-openai>.openai.azure.com/",
    "EXTENDED_ASSESSMENT_OPENAI_DEPLOYMENT": "gpt-5",
    "EXTENDED_ASSESSMENT_OPENAI_API_VERSION": "2024-12-01-preview",
    "EXTENDED_ASSESSMENT_OPENAI_MAX_TOKENS": "4000",
    "EXTENDED_ASSESSMENT_OPENAI_TEMPERATURE": "0.2",
    "EXTENDED_ASSESSMENT_OPENAI_TIMEOUT_SECONDS": "120",
    "EXTENDED_ASSESSMENT_USE_FALLBACK": "false",

    "LOCAL_DAM_BASE_URL": "http://localhost:8000",
    "LOCAL_DAM_INITIATE_PATH": "initiate",
    "LOCAL_DAM_PREDICTION_PATH": "predict",
    "LOCAL_DAM_MODEL_ID": "KintsugiHealth/dam",
    "LOCAL_DAM_TIMEOUT_SECONDS": "300",
    "LOCAL_DAM_WARMUP_ON_STARTUP": "true",
    "LOCAL_DAM_HEALTH_PATH": "health",
    "LOCAL_DAM_WARMUP_TIMEOUT_SECONDS": "600",
    "LOCAL_DAM_WARMUP_POLL_SECONDS": "5",

    "AZURE_SPEECH_ENDPOINT": "https://<your-speech>.cognitiveservices.azure.com/",
    "AZURE_SPEECH_KEY": "",
    "AZURE_SPEECH_REGION": "eastus2",
    "AZURE_SPEECH_LOCALE": "en-US",
    "AZURE_SPEECH_API_VERSION": "2024-11-15",
    "AZURE_SPEECH_ENHANCED_MODE": "false",

    "AZURE_CONTENT_UNDERSTANDING_ENDPOINT": "https://<your-content-understanding>.services.ai.azure.com/",
    "DocumentIntelligenceEndpoint": "https://<your-docintelligence>.cognitiveservices.azure.com/",
    "DSM5_DOCUMENT_INTELLIGENCE_ENDPOINT": "https://<your-docintelligence>.cognitiveservices.azure.com/",
    "DSM5_CONTAINER_NAME": "dsm5-data",
    "DSM5_EXTRACTION_METHOD": "CONTENT_UNDERSTANDING",


    "ENTRA_TENANT_ID": "<tenant-id>",
    "ENTRA_CLIENT_ID": "<api-client-id>",
    "AZURE_TENANT_ID": "<tenant-id>",
    "AZURE_CLIENT_ID": "<user-assigned-managed-identity-client-id>"
  }
}
