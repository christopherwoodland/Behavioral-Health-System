# =============================================================================
# Docker Environment Variables
# =============================================================================
# Copy this file to docker.env and fill in your values:
#   cp docker.env.example docker.env
#
# docker.env is gitignored — never commit it with real secrets.
# Used by: docker compose --env-file docker.env -f docker-compose.development.yml up -d
# =============================================================================

# Azure Identity (Service Principal)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure Storage
STORAGE_ACCOUNT_NAME=
DSM5_STORAGE_ACCOUNT_NAME=

# Application Insights (leave empty to disable)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Azure Speech (transcription)
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_REGION=

# Azure OpenAI (risk assessments, grammar correction)
AZURE_OPENAI_ENDPOINT=

# Extended Assessment OpenAI (GPT-5/O3 — leave empty to use standard deployment)
EXTENDED_ASSESSMENT_OPENAI_ENDPOINT=

# Content Understanding / Document Intelligence (leave empty to disable)
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=
DOCUMENT_INTELLIGENCE_ENDPOINT=
DSM5_DOCUMENT_INTELLIGENCE_ENDPOINT=

# Agent endpoint (leave empty to disable)
AGENT_ENDPOINT=

# Entra ID auth enforcement (leave empty to disable)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=

# Web Frontend
VITE_API_BASE_URL=http://bhs-api-dev:80/api
VITE_ENABLE_AUTH=false
VITE_AZURE_ADMIN_GROUP_ID=
VITE_AZURE_AUTHORITY=
VITE_AZURE_CLIENT_ID=
VITE_AZURE_CONTROL_PANEL_GROUP_ID=
VITE_AZURE_KNOWN_AUTHORITIES=
VITE_AZURE_REDIRECT_URI=
VITE_AZURE_TENANT_ID=
